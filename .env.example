# Claim Structurer backend config

# Production/default mode. Use "mock" only for explicit local demos/tests.
CLAIM_STRUCTURER_EXTRACTION_MODE=azure

# Local storage. Relative paths are resolved from the process working directory.
CLAIM_STRUCTURER_DATA_DIR=.claim_structurer_data
CLAIM_STRUCTURER_MAX_UPLOAD_BYTES=209715200

# PDF ingest is API-only and must use claim-file-splitter.
CLAIM_STRUCTURER_PDF_SPLITTER_MODE=required
CLAIM_STRUCTURER_PDF_SPLITTER_DEFAULT_CATEGORY=other
CLAIM_STRUCTURER_DOCUMENT_CATEGORIES_PATH=config/document_categories.json

# PDF document-level extraction renders split PDFs as page images.
CLAIM_STRUCTURER_DOCUMENT_EXTRACTION_PAGE_BATCH_SIZE=5
CLAIM_STRUCTURER_DOCUMENT_EXTRACTION_RENDER_DPI=160
CLAIM_STRUCTURER_DOCUMENT_EXTRACTION_IMAGE_FORMAT=jpeg
CLAIM_STRUCTURER_DOCUMENT_EXTRACTION_IMAGE_QUALITY=85

# Azure AI Foundry / Projects config used by extraction and PDF splitter.
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_NAME=

# Optional splitter-native names. Leave blank when using the Foundry values above.
AZURE_AI_PROJECT_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
